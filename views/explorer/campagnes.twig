<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Tamghrabit - Explorer les campagnes</title>
		<link rel="stylesheet" href="{{ url('public/css/dashboard.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/campagne-index.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/all.min.css') }}">
	</head>
	<body>

		<div class="main-wrapper">
			{% include 'layouts/sidebar.twig' %}

			<main>
				<header>
					<div class="search-bar">
						<i class="fa-solid fa-magnifying-glass"></i>
						<input type="text" placeholder="Rechercher...">
					</div>

					<div class="action-buttons">
						<button class="icon-btn">
							<i class="fa-solid fa-moon"></i>
						</button>
						<a href="{{url(route('chat'))}}" class="icon-btn">
							<i class="fa-solid fa-message"></i>
						</a>
						<button class="icon-btn">
							<i class="fa-solid fa-bell"></i>
						</button>

						<div class="action-buttons">
							<div class="profile-container">
								<img src="{{ currentUser.imageProfile ? url('public/storage/profiles/' ~ currentUser.imageProfile) : url('public/images/default-profile.png') }}" class="avatar">
								<div class="user-info">
									<span class="nom">{{ currentUser.prenom }}
										{{ currentUser.nom }}</span>
									<span class="email">{{ currentUser.email }}</span>
								</div>
							</div>
						</div>
					</div>
				</header>

				<section class="dashboard-body">
					<div class="categories-row">
						<button class="cat-pill active">Tout</button>
						<button class="cat-pill">Santé</button>
						<button class="cat-pill">Éducation</button>
						<button class="cat-pill">Social</button>
						<button class="cat-pill">Nature</button>
					</div>

					<div class="section-header">
						<h2>Explorer les campagnes</h2>
						<p>Soutenez des projets vérifiés par notre communauté.</p>
					</div>

					<div class="campaigns-grid">

						{% for c in campagnes %}

							{% set type = (c.type == 'associationassociation') ? 'association' : c.type %}

							<div class="campaign-card type-{{ type }}">
								<div class="card-image">
									<img src="{{ url('public/storage/campagnes/' ~ c.image) }}" alt="{{ c.titre }}">
									<span class="badge-cat">{{ type | capitalize }}</span>
								</div>

								<div class="card-content">
									<div class="org-info">
										{% if c.organisationNom %}
											<div class="initials-avatar">{{ c.organisationNom|slice(0, 1) }}</div>
										{% else %}
											<img src="{{ c.imageProfile ? url('public/storage/profiles/' ~ c.imageProfile) : url('public/images/profil.png') }}" class="mini-logo">
										{% endif %}

										<span>{{ c.organisationNom ?: c.nomDestinataire ~ ' ' ~ c.prenomDestinataire }}</span>
									</div>

									<h3 class="card-title">{{ c.titre }}</h3>

									{% if type in ['argent', 'parrainage', 'association'] %}
										<div class="progress-container">
											<div class="progress-bar">
												<div class="progress-fill" style="width: {{ c.percentage }}%;"></div>
											</div>
											<div class="progress-stats">
												<span>
													<strong>{{ c.montantCollecte | number_format(0, '.', ' ') }}
														DH
													</strong>
													/
													{{ c.objectifMontant | number_format(0, '.', ' ') }}
													DH</span>
												<span>{{ c.percentage }}%</span>
											</div>
										</div>
									{% endif %}

									{% if type == 'nature' %}
										<div class="item-needed">
											<i class="fa-solid fa-box-open"></i>
											Objectif:
											{{ c.nomArticle }}
										</div>
										<p class="card-desc">{{ c.description | slice(0, 80) }}...</p>
									{% endif %}

									{% if type == 'parrainage' %}
										<div class="tags-row">
											<span class="tag tag-blue">
												<i class="fa-solid fa-repeat"></i>
												{{ c.frequence | capitalize }}</span>
										</div>
									{% endif %}

									<div class="card-footer">
										<span class="footer-info">
											<i class="fa-regular fa-clock"></i>
											{{ c.days_left }}j restants
										</span>
										<a href="{{ url('campagne/show') }}?id={{ c.id }}" class="btn-primary">
											{% if type == 'parrainage' %}
												Parrainer
											{% elseif type == 'nature' %}
												Contribuer
											{% else %}
												Donner
											{% endif %}
										</a>
									</div>
								</div>
							</div>
						{% else %}
							<p>Aucune campagne disponible pour le moment.</p>
						{% endfor %}

					</div>
				</section>
			</main>
		</div>

		<script>

			document.querySelectorAll('.cat-pill').forEach(pill => {
pill.addEventListener('click', () => {
document.querySelector('.cat-pill.active').classList.remove('active');
pill.classList.add('active');
});
});
		</script>
	</body>
</html>

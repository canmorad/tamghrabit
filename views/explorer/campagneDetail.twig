<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ c.titre }}
			| Tamghrabit</title>
		<link rel="stylesheet" href="{{ url('public/css/all.min.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/campagne-detail.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/footer.css') }}">
	</head>
	<body>
		<div class="page-wrapper">
			<header class="main-header">
				<div class="container">
					<a href="{{ url(route('explorer')) }}" class="back-link">
						<i class="fa-solid fa-arrow-left"></i>
						Retour aux campagnes
					</a>
				</div>
			</header>

			<div class="container campagne-detail-container">
				<main class="main-content">
					<div class="badge-category">{{ c.categorieNom }}</div>
					<h1>{{ c.titre }}</h1>

					<div class="main-image-wrapper">
						<img src="{{ url('public/storage/campagnes/' ~ c.image) }}" alt="{{ c.titre }}">
					</div>

					<div class="content-body">
						<div class="author-info">
							<div class="avatar-sm">
								<i class="fa-solid fa-building-ngo"></i>
							</div>
							<div class="author-text">
								<p>Organisée par
									<strong>{{ c.organisationNom ?: 'Donateur vérifié' }}</strong>
								</p>
								<span>
									<i class="fa-solid fa-check-circle"></i>
									Vérifié</span>
							</div>
						</div>

						<div class="description-section">
							<h3>L'histoire de cette campagne</h3>
							<p>{{ c.description | nl2br }}</p>
						</div>
					</div>
				</main>

				<aside class="donation-sidebar">
					{% set successMsg = flush('success') %}

					{% set errorMsg = flush('error') %}

					{% if successMsg or errorMsg %}
						<div class="alert alert-{{ successMsg ? 'success' : 'error' }}" id="flash-alert">
							{{ successMsg ?: errorMsg }}
						</div>

						<script>
							setTimeout(() => {
							const alert = document.getElementById('flash-alert');
							if (alert) 
							alert.style.display = 'none';



							}, 4000);
						</script>
					{% endif %}
					<div class="sticky-card">
						{% if c.type != 'nature' %}
							<div class="progress-section">
								<div class="progress-header">
									<span class="percentage">{{ c.percentage }}%</span>
									<span class="days">
										<i class="fa-regular fa-clock"></i>
										{{ c.days_left }}j restants</span>
								</div>
								<div class="bar-container">
									<div class="bar-fill" style="width: {{ c.percentage }}%;"></div>
								</div>
								<div class="stats">
									<span class="current">{{ c.montantCollecte | number_format(0, '.', ' ') }}
										DH</span>
									<span class="goal">sur
										{{ c.objectifMontant | number_format(0, '.', ' ') }}
										DH</span>
								</div>
							</div>
						{% else %}
							<div class="nature-info">
								<strong>Besoin en :</strong>
								{{ c.nomArticle }}
								({{ c.typeDon }})
							</div>
						{% endif %}

						<div class="action-buttons">
							{% if c.type != 'nature' %}
								<form action="{{ url('donation/checkout') }}" method="POST" style="width: 100%;">
									<input type="hidden" name="idCampagne" value="{{ c.id }}">

									<div class="amount-input-wrapper" style="margin-bottom: 12px;">
										<input type="number" name="montant" placeholder="Montant en DH" class="form-control" min="10" style="width: 100%; padding: 15px; border-radius: 10px; border: 1px solid #ddd;">
									</div>
									<button type="submit" class="btn-primary-lg" style="width: 100%;">
										<i class="fa-solid fa-heart"></i>
										Je soutiens financièrement
									</button>
								</form>
							{% else %}
								<button class="btn-primary-lg" onclick="openChat('{{ c.idAdherent }}', '{{ c.prenomDestinataire }} {{ c.nomDestinataire }}')">
									Proposer mon aide (Nature)
								</button>
							{% endif %}

							<button class="btn-message-outline" onclick="openChat('{{ c.idAdherent }}', '{{ c.prenomDestinataire }} {{ c.nomDestinataire }}')">
								<i class="fa-regular fa-comment-dots"></i>
								Contacter l'organisateur
							</button>

							<button class="btn-secondary-lg">
								<i class="fa-solid fa-share-nodes"></i>
								Partager
							</button>
						</div>

						<div class="trust-footer">
							<i class="fa-solid fa-shield-halved"></i>
							Don sécurisé
						</div>
					</div>
				</aside>
			</div>
		</div>

		<input type="hidden" id="currentConvId" value="">

		<div id="chatModal" class="chat-modal">
			<div class="chat-window">
				<div class="chat-header">
					<div class="user-meta">
						<img src="{{ c.imageProfile ? url('public/storage/profiles/' ~ c.imageProfile) : url('public/images/default-profile.png') }}" alt="User" class="chat-avatar">
						<div class="user-status">
							<strong>{{ c.organisation_nom ?: 'Organisateur' }}</strong>
							<span>En ligne</span>
						</div>
					</div>
					<button class="close-chat" onclick="toggleChat()">&times;</button>
				</div>
				<div class="chat-body" id="chatBody"></div>
				<div class="chat-footer">
					<textarea placeholder="Votre message..." id="chatInput"></textarea>
					<button class="send-btn" id="sendBtn" disabled>
						<i class="fa-solid fa-paper-plane"></i>
					</button>
				</div>
			</div>
		</div>

		{% include 'layouts/footer.twig' %}
		<script src="{{ url('public/js/chat.js') }}"></script>
	</body>
</html>

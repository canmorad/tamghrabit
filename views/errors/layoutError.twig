<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Erreur {{ code }}</title>
    <link rel="stylesheet" href="{{ url('public/css/errors.css') }}">
</head>
<body>
    <div class="error-container">

        <div class="error-code">
            {{ code }}
        </div>

        <h1 class="error-title">
            {{ title }}
        </h1>

        <p class="error-message">
            ⚠️ {{ message }}
        </p>

        <a href="{{ url('/') }}" class="btn">
            Retour à l'accueil
        </a>

    </div>
</body>
</html>
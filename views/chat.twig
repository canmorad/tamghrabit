<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Tamghrabit - Messagerie</title>
		<link rel="stylesheet" href="{{ url('public/css/dashboard.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/chat.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/all.min.css') }}">
	</head>
	<body>
		<div class="main-wrapper">
			{% include 'layouts/sidebar.twig' %}

			<main>
				<input type="hidden" id="currentConvId" value="">
				<header>
					<div class="search-bar">
						<i class="fa-solid fa-magnifying-glass"></i>
						<input type="text" placeholder="Rechercher une discussion...">
					</div>
					<div class="action-buttons">
						<div class="profile-container">
							<img src="{{ user.imageProfile ? url('public/storage/profiles/' ~ user.imageProfile) : url('public/images/default-profile.png') }}" class="avatar">
							<div class="user-info">
								<span class="nom">{{ user.prenom }}
									{{ user.nom }}</span>
								<span class="email">{{ user.email }}</span>
							</div>
						</div>
					</div>
				</header>

				<div class="dashboard-body chat-page-wrapper">
					<div class="messaging-card">
						<aside class="chat-sidebar">
							<div class="chat-sidebar-header">
								<h2>Messages</h2>
							</div>

							<div class="chat-list">
								{% for conv in conversations %}
									<div class="chat-item" onclick="openDiscussion('{{ conv.idConversation }}', '{{ conv.prenomDestinataire }} {{ conv.nomDestinataire }}', '{{ conv.imageDestinataire ? url('public/storage/profiles/' ~ conv.imageDestinataire) : url('public/images/default-profile.png') }}')">
										<div class="avatar-wrapper">
											<img src="{{ conv.imageDestinataire ? url('public/storage/profiles/' ~ conv.imageDestinataire) : url('public/images/default-profile.png') }}">
										</div>
										<div class="chat-item-info">
											<div class="chat-item-top">
												<strong>{{ conv.prenomDestinataire }}
													{{ conv.nomDestinataire }}</strong>

												<div class="chat-item-actions">
													<span class="time">{{ conv.dateDernierMessage | date('H:i') }}</span>

													<div class="dropdown-container">
														<button class="action-dots" onclick="toggleDropdown(event, this)">
															<i class="fa-solid fa-ellipsis-vertical"></i>
														</button>
														<div class="dropdown-menu">
															<a href="#" class="delete-btn" onclick="deleteConversation(event, '{{ conv.idConversation }}')">
																<i class="fa-solid fa-trash"></i>
																Supprimer
															</a>
														</div>
													</div>
												</div>
											</div>
											<p class="preview text-truncate">
												{% if conv.idDernierExpediteur == user.id %}Vous:
												{% endif %}
												{{ conv.dernierMessage ?: 'Aucun message' }}
											</p>
										</div>
									</div>
								{% else %}
									<p class="empty-state">Aucune conversation.</p>
								{% endfor %}
							</div>
						</aside>

						<section class="chat-view">
							<div class="chat-view-header">
								<div class="current-user">
									<img src="{{ url('public/images/default-profile.png') }}" class="avatar-sm">
									<div>
										<h4>Sélectionnez</h4>
										<span class="status">En ligne</span>
									</div>
								</div>
							</div>

							<div class="chat-messages-area" id="chatBody"></div>

							<div class="chat-input-wrapper">
								<div class="input-container">
									<textarea placeholder="Écrivez votre message..." id="messageInput"></textarea>
									<button class="send-btn" id="sendBtn" disabled>
										<i class="fa-solid fa-paper-plane"></i>
									</button>
								</div>
							</div>
						</section>
					</div>
				</div>
			</main>
		</div>

		<script src="{{ url('public/js/conversation.js') }}"></script>
	</body>
</html>

<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tamghrabit - Plateforme de Dons</title>
    <link rel="stylesheet" href="{{ url('public/css/register.css') }}">
    <link rel="stylesheet" href="{{ url('public/css/footer.css') }}">
    <link rel="stylesheet" href="{{ url('public/css/header.css') }}">
    <link rel="stylesheet" href="{{ url('public/css/all.min.css') }}">
</head>

<body>

    {% include 'layouts/header.twig' %}

    <div class="register-page">
        <div class="register-container">
            <div class="register-form-side">
                <div class="register-header">
                    <div class="logo">
                        <img src="{{ url('public/images/logo.png') }}" alt="Tamghrabit Logo">
                    </div>
                    <h1>Créer un compte</h1>
                    <p>Inscrivez-vous pour commencer votre aventure</p>
                </div>

                {% set errors = session_errors() %}
                
                {% if errors is not empty %}
                    <div class="alert alert-danger">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <p>
                            {% for message in errors %}
                                {{ message }}<br>
                            {% endfor %}
                        </p>
                    </div>
                {% endif %}

                <form class="form-container" method="POST" action="{{ route('register.store') }}">

                    <div class="section-genre">
                        <label class="titre-section">Vous êtes</label>
                        <div class="options-genre">
                            <label class="item-genre">
                                <input type="radio" name="genre" value="femme">
                                <div class="carte-genre">
                                    <i class="fa-solid fa-venus"></i>
                                    <span>Femme</span>
                                </div>
                            </label>

                            <label class="item-genre">
                                <input type="radio" name="genre" value="homme">
                                <div class="carte-genre">
                                    <i class="fa-solid fa-mars"></i>
                                    <span>Homme</span>
                                </div>
                            </label>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Nom</label>
                            <input type="text" name="nom" placeholder="Votre nom">
                        </div>
                        <div class="form-group">
                            <label>Prénom</label>
                            <input type="text" name="prenom" placeholder="Votre prénom">
                        </div>
                    </div>

                    <div class="form-group">
                        <label>E-mail</label>
                        <input type="email" name="email" placeholder="exemple@mail.com">
                    </div>

                    <div class="form-group">
                        <label>Date de naissance</label>
                        <input type="date" name="dateNaissance">
                    </div>

                    <div class="form-group">
                        <label>Mot de passe</label>
                        <div class="input-wrapper">
                            <input type="password" name="password" class="passInput" placeholder="••••••••">
                            <i class="fa-regular fa-eye-slash togglePass"></i>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Confirmer le mot de passe</label>
                        <div class="input-wrapper">
                            <input type="password" name="confirmePassword" class="passInput" placeholder="•••••••">
                            <i class="fa-regular fa-eye-slash togglePass"></i>
                        </div>
                    </div>

                    <div class="form-checkbox">
                        <input type="checkbox" id="terms">
                        <label for="terms">J'accepte la <strong>Politique de confidentialité</strong> et les
                            <strong>Conditions d'utilisation</strong>.</label>
                    </div>

                    <button type="submit" class="bouton-submit">Continuer</button>

                    <p class="login-link">Vous avez déjà un compte ? <a href="{{ route('login.create') }}">Se
                            connecter</a></p>
                </form>
            </div>

            <div class="register-image-side">
                <div class="image-overlay">
                    <h2>BÂTIR. CHANGER.</h2>
                </div>
            </div>
        </div>
    </div>

    {% include 'layouts/footer.twig' %}

    <script>
        const togglePass = document.querySelectorAll('.togglePass');
        togglePass.forEach(item => {
            item.addEventListener('click', () => {
                const input = item.previousElementSibling;
                const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                input.setAttribute('type', type);
                item.classList.toggle('fa-eye');
                item.classList.toggle('fa-eye-slash');
            });
        });
    </script>

</body>
</html>
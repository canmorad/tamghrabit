<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Tamghrabit - Validation des RIBs</title>
		<link rel="stylesheet" href="{{ url('public/css/dashboard.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/ribs-admin.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/all.min.css') }}">
	</head>
	<body>
		<div class="main-wrapper">
			{% include 'layouts/sidebar.twig' %}
			<main>
				<header>
					<div class="search-bar">
						<i class="fa-solid fa-magnifying-glass"></i>
						<input type="text" placeholder="Rechercher un RIB ou un adhérent...">
					</div>
					<div class="profile-container">
						<img src="{{ currentUser.imageProfile ? url('public/storage/profiles/' ~ currentUser.imageProfile) : url('public/images/default-profile.png') }}" class="avatar">
						<div class="user-info">
							<span class="nom">{{ currentUser.prenom }}
								{{ currentUser.nom }}</span>
							<span class="email">{{ currentUser.email }}</span>
						</div>
					</div>
				</header>

				<div class="dashboard-body">
					<div class="verify-container">
						<div class="table-header">
							<h2>
								<i class="fa-solid fa-building-columns"></i>
								Validation des RIBs
							</h2>
							<p class="subtitle">Examinez et validez les coordonnées bancaires des adhérents.</p>
						</div>

						<table>
							<thead>
								<tr>
									<th>Adhérent</th>
									<th>Numéro RIB</th>
									<th>Date d'envoi</th>
									<th style="text-align: right;">Action</th>
								</tr>
							</thead>
							<tbody>
								{% for item in ribs %}
									<tr>
										<td>
											<div class="user-cell">
												<img src="{{ item.imageProfile ? url('public/storage/profiles/' ~ item.imageProfile) : url('public/images/profil.png') }}">
												<div class="info">
													<span class="name">{{ item.prenom }}
														{{ item.nom }}</span>
													<span class="email">{{ item.email }}</span>
												</div>
											</div>
										</td>
										<td>
											<code>{{ item.rib }}</code>
										</td>
										<td>
											<i class="fa-regular fa-calendar" style="margin-right: 5px; opacity: 0.5;"></i>
											{{ item.dateCreation|date("d M Y") }}</td>
										<td style="text-align: right;">
											<button class="view-btn" onclick="openRibModal('{{ item.prenom|e('js') }} {{ item.nom|e('js') }}', '{{ item.rib }}', '{{ url('public/storage/ribs/' ~ item.attestationRib) }}', '{{ item.id }}')">
												<i class="fa-solid fa-eye"></i>
												Voir
											</button>
										</td>
									</tr>
								{% else %}
									<tr>
										<td colspan="4" class="empty-state" style="padding: 80px; text-align: center; color: #64748b;">
											<i class="fa-solid fa-inbox" style="font-size: 40px; display: block; margin-bottom: 15px; opacity: 0.2;"></i>
											Aucun RIB en attente de validation.
										</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				</div>
			</main>
		</div>

		<div id="ribModal" class="modal">
			<div class="modal-content">
				<div class="modal-header">
					<div>
						<h3 id="r-adherentName" style="margin-bottom: 5px;">---</h3>

					</div>
					<span class="close" onclick="closeRibModal()">&times;</span>
				</div>

				<div class="modal-body">
					<div class="rib-info-box">
						<label>RIB DÉCLARÉ :</label>
						<div id="r-ribValue"></div>
					</div>
					<div class="document-preview">
						<label>ATTESTATION :</label>
						<div id="imageGallery" class="document-grid">
							<div class="doc-item" onclick="previewImage(document.getElementById('r-attestationImg').src)">
								<img id="r-attestationImg" src="">
								<span>Page 1</span>
							</div>

						</div>

					</div>
					<div class="rejection-area">
						<label>
							<i class="fa-solid fa-envelope-open-text"></i>
							Motif du refus :
						</label>
						<textarea id="ribRejectionMessage" placeholder="Expliquez le motif du refus..."></textarea>
					</div>
				</div>

				<div class="modal-footer">
					<button class="btn-danger" onclick="handleRibAction('refuse')">Refuser</button>
					<button class="btn-success" onclick="handleRibAction('approuvee')">Approuver</button>
				</div>
			</div>
		</div>

		<div id="imagePreviewModal" class="image-viewer-modal">
			<span class="close-viewer" onclick="closeImageViewer()">&times;</span>
			<div class="viewer-wrapper" id="viewerWrapper">
				<img id="fullImage">
			</div>
			<div class="viewer-controls">
				<button onclick="zoomImage(0.2)">
					<i class="fa-solid fa-plus"></i>
				</button>
				<button onclick="resetZoom()">
					<i class="fa-solid fa-rotate-left"></i>
				</button>
				<button onclick="zoomImage(-0.2)">
					<i class="fa-solid fa-minus"></i>
				</button>
			</div>
		</div>

		<script>
			let currentRibId = null;
            let currentZoom = 1;

            function openRibModal(name, rib, imgUrl, id) {
            currentRibId = id;
            document.getElementById('r-adherentName').innerText = name;
            document.getElementById('r-ribValue').innerText = rib;
            document.getElementById('r-attestationImg').src = imgUrl;
            document.getElementById('ribRejectionMessage').value = "";
            document.getElementById('ribModal').classList.add('open');
            }

            function closeRibModal() {
            document.getElementById('ribModal').classList.remove('open');
            }

            function previewImage(src) {
            const viewer = document.getElementById('imagePreviewModal');
            viewer.style.display = "flex";
            document.getElementById('fullImage').src = src;

            resetZoom();

            }

            function closeImageViewer() {
              document.getElementById('imagePreviewModal').style.display = "none";
            }

            function zoomImage(step) {
            currentZoom += step;
            currentZoom = Math.min(Math.max(0.5, currentZoom), 3);
            document.getElementById('fullImage').style.transform = `scale(${currentZoom})`;
            }

            function resetZoom() {
            currentZoom = 1;
            document.getElementById('fullImage').style.transform = "scale(1)";
            }

            async function handleRibAction(type) {
            const message = document.getElementById('ribRejectionMessage').value;
            if (type === 'refuse' && ! message.trim()) {
            alert("Veuillez saisir un motif de refus.");
            return;
            }
            if (!confirm(type === 'approuvee' ? "Valider ce RIB ?" : "Refuser ce document ?")) 
            return;



            const formData = new FormData();
            formData.append('id', currentRibId);
            formData.append('status', type);
            formData.append('reason', message);

            try {
            const response = await fetch('{{ url("/admin/ribs/validate") }}', {
            method: 'POST',
            body: formData
            });
            const data = await response.json();
            if (data.success || data.type === 'success') {
            location.reload();
            } else {
            alert(data.message || "Une erreur est survenue");
            }
            } catch (error) {
            alert("Erreur de connexion au serveur.");
            }
            }

            window.onclick = function (event) {
            if (event.target.id === 'ribModal') 
            closeRibModal();


            if (event.target.id === 'imagePreviewModal') 
            closeImageViewer();


            }
		</script>
	</body>
</html>

<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Tamghrabit - Admin</title>
		<link rel="stylesheet" href="{{ url('public/css/dashboard.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/users-admin.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/all.min.css') }}">
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="main-wrapper">
			{% include 'layouts/sidebar.twig' %}

			<main>
				<header>
					<div class="search-bar">
						<i class="fa-solid fa-magnifying-glass"></i>
						<input type="text" id="userSearch" placeholder="Rechercher par nom ou email...">
					</div>
					<div class="action-buttons">
						<div class="profile-container">
							<img src="{{ currentUser.imageProfile ? url('public/storage/profiles/' ~ currentUser.imageProfile) : url('public/images/default-profile.png') }}" class="avatar">
							<div class="user-info">
								<span class="nom">{{ currentUser.prenom }}
									{{ currentUser.nom }}</span>
								<span class="email">{{ currentUser.email }}</span>
							</div>
						</div>
					</div>
				</header>

				<div class="dashboard-body">
					<div class="users-container">
						<div class="table-header">
							<h2>Utilisateurs</h2>
							<div class="controls">
								<div class="filter-select">
									Statut:
									<select>
										<option>Tous</option>
										<option>Vérifié</option>
										<option>En attente</option>
										<option>Bloqué</option>
									</select>
								</div>
							</div>
						</div>

						<table>
							<thead>
								<tr>
									<th>Nom Complet</th>
									<th>Statut</th>
									<th>Email</th>
									<th>Inscrit le</th>
								</tr>
							</thead>
							<tbody>
								{% for user in users %}
									<tr>
										<td>
											<div class="user-cell">
												<img src="{{ user.imageProfile ? url('public/storage/profiles/' ~ user.imageProfile) : url('public/images/default-profile.png') }}">
												<div class="name-wrapper">
													{{ user.prenom }}
													{{ user.nom }}
													{% if user.estVerifie %}
														<i class="fa-solid fa-circle-check verify-badge"></i>
													{% endif %}
												</div>
											</div>
										</td>
										<td>
											{% if user.estVerifie %}
												<span class="status-indicator verifie">Vérifié</span>
											{% else %}
												<span class="status-indicator en_attente">En attente</span>
											{% endif %}
										</td>
										<td style="color: #64748b;">{{ user.email }}</td>
										<td style="color: #64748b;">{{ user.time_ago }}</td>
									</tr>
								{% else %}
									<tr>
										<td colspan="5" style="text-align: center; padding: 30px; color: #94A3B8;">
											Aucun utilisateur enregistré.
										</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>


					</div>
				</div>
			</main>
		</div>

		<script></script>
	</body>
</html>

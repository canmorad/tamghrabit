<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tamghrabit - Dashboard Overview</title>
    
    <link rel="stylesheet" href="{{ url('public/css/dashboard.css') }}">
    <link rel="stylesheet" href="{{ url('public/css/dashboard-admin.css') }}">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="main-wrapper">
        {% include 'layouts/sidebar.twig' %}
        
        <main>
            <header>
                <div class="welcome-text">
                    <h1>Tableau de bord</h1>
                    <p>Bienvenue, {{ currentUser.prenom }} ! Voici ce qui se passe aujourd'hui.</p>
                </div>
                <div class="action-buttons">
						<div class="profile-container">
							<img src="{{ currentUser.imageProfile ? url('public/storage/profiles/') ~ currentUser.imageProfile : url('public/images/default-profile.png')}}" alt="Admin" class="avatar">
							<div class="user-info">
								<span class="nom">{{ currentUser.nom ~ ' ' ~ currentUser.prenom }}</span>
								<span class="email">{{ currentUser.email }}</span>
							</div>
						</div>
					</div>
            </header>

            <div class="dashboard-content">
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="icon-box blue"><i class="fa-solid fa-users"></i></div>
                        <div class="details">
                            <span class="label">Utilisateurs</span>
                            <span class="value">1,284</span>
                            <span class="trend up"><i class="fa-solid fa-arrow-up"></i> 12%</span>
                        </div>
                    </div>
                    
                    <div class="stat-card">
                        <div class="icon-box green"><i class="fa-solid fa-bullhorn"></i></div>
                        <div class="details">
                            <span class="label">Campagnes</span>
                            <span class="value">42</span>
                            <span class="trend up"><i class="fa-solid fa-arrow-up"></i> 5%</span>
                        </div>
                    </div>
                    
                    <div class="stat-card">
                        <div class="icon-box yellow"><i class="fa-solid fa-wallet"></i></div>
                        <div class="details">
                            <span class="label">Revenus (DH)</span>
                            <span class="value">12,450</span>
                            <span class="trend down"><i class="fa-solid fa-arrow-down"></i> 2%</span>
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="icon-box purple"><i class="fa-solid fa-check-to-slot"></i></div>
                        <div class="details">
                            <span class="label">RIB Validés</span>
                            <span class="value">85%</span>
                            <span class="trend up"><i class="fa-solid fa-arrow-up"></i> 8%</span>
                        </div>
                    </div>
                </div>

                <div class="charts-container">
                    <div class="chart-box main-chart">
                        <h3>Performance des Campagnes</h3>
                        <canvas id="analyticsChart"></canvas>
                    </div>
                    <div class="chart-box side-chart">
                        <h3>Répartition des Adhérents</h3>
                        <canvas id="distributionChart"></canvas>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        // Line Chart - Performance
        const ctx1 = document.getElementById('analyticsChart').getContext('2d');
        new Chart(ctx1, {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                datasets: [{
                    label: 'Ventes (DH)',
                    data: [5000, 7000, 6500, 9000, 11000, 12450],
                    borderColor: '#C5F82A',
                    backgroundColor: 'rgba(197, 248, 42, 0.1)',
                    fill: true,
                    tension: 0.4,
                    borderWidth: 3
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f1f5f9' } },
                    x: { grid: { display: false } }
                }
            }
        });

        // Doughnut Chart - Distribution
        const ctx2 = document.getElementById('distributionChart').getContext('2d');
        new Chart(ctx2, {
            type: 'doughnut',
            data: {
                labels: ['Actifs', 'Inactifs', 'En attente'],
                datasets: [{
                    data: [70, 20, 10],
                    backgroundColor: ['#C5F82A', '#062121', '#E2E8F0'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                cutout: '70%',
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
                }
            }
        });
    </script>
</body>
</html>
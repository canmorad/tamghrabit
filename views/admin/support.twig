<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Paramètres - Tamghrabit</title>
		<link rel="stylesheet" href="{{ url('public/css/dashboard.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/support.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/all.min.css') }}">
	</head>
	<body>

		<div class="main-wrapper">
			{% include 'layouts/sidebar.twig' %}

			<main>
				<header>
					<div class="search-bar">
						<i class="fa-solid fa-magnifying-glass"></i>
						<input type="text" placeholder="Rechercher dans les paramètres...">
					</div>
					<div class="action-buttons">
						<button class="icon-btn">
							<i class="fa-solid fa-moon"></i>
						</button>
						<a href="{{url(route('chat'))}}" class="icon-btn">
							<i class="fa-solid fa-message"></i>
						</a>
						<button class="icon-btn">
							<i class="fa-solid fa-bell"></i>
						</button>

						<div class="action-buttons">
							<div class="profile-container">
								<img src="{{ currentUser.imageProfile ? url('public/storage/profiles/' ~ currentUser.imageProfile) : url('public/images/default-profile.png') }}" class="avatar">
								<div class="user-info">
									<span class="nom">{{ currentUser.prenom }}
										{{ currentUser.nom }}</span>
									<span class="email">{{ currentUser.email }}</span>
								</div>
							</div>
						</div>
					</div>
				</header>

				<section class="dashboard-body">
					<div class="support-container">

						<div class="support-info-card">
							<div>
								<h2>Besoin d'aide ?</h2>
								<p>Notre équipe est là pour vous accompagner. N'hésitez pas à nous contacter via le formulaire ou directement.</p>
							</div>

							<div class="contact-item">
								<div class="icon-circle">
									<i class="fa-solid fa-envelope"></i>
								</div>
								<div class="details">
									<span>Email Support</span>
									<strong>support@tamghrabit.ma</strong>
								</div>
							</div>

							<div class="contact-item">
								<div class="icon-circle">
									<i class="fa-solid fa-phone"></i>
								</div>
								<div class="details">
									<span>Téléphone</span>
									<strong>+212 6 00 00 00 00</strong>
								</div>
							</div>

							<div class="contact-item">
								<div class="icon-circle">
									<i class="fa-brands fa-whatsapp"></i>
								</div>
								<div class="details">
									<span>WhatsApp</span>
									<strong>+212 6 00 00 00 00</strong>
								</div>
							</div>
						</div>

						{% set successMsg = flush('success') %}
						
						{% set errorMsg = flush('error') %}

						{% if successMsg or errorMsg %}
							<div class="alert alert-{{ successMsg ? 'success' : 'error' }}" id="flash-alert">
								{{ successMsg ?: errorMsg }}
							</div>

							<script>
								setTimeout(() => {
									const alert = document.getElementById('flash-alert');
									if (alert) 
									alert.style.display = 'none';

									}, 4000);
							</script>
						{% endif %}

						<div class="support-form-card">
							<form action="support/send" method="POST">
								<div class="form-group">
									<label>Sujet de votre message</label>
									<input type="text" name="subject" placeholder="Ex: Problème de connexion" required>
								</div>

								<div class="form-group">
									<label>Votre message</label>
									<textarea name="message" placeholder="Décrivez votre problème en détail..." required></textarea>
								</div>

								<button type="submit" class="btn-send">
									<i class="fa-solid fa-paper-plane"></i>
									Envoyer le message
								</button>
							</form>
						</div>

					</div>
				</section>
			</main>
		</div>

		<script></script>
	</body>

</html>

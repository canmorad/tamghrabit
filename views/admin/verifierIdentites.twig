<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tamghrabit - Admin</title>
    <link rel="stylesheet" href="{{ url('public/css/dashboard.css') }}">
    <link rel="stylesheet" href="{{ url('public/css/identites-admin.css') }}">
    <link rel="stylesheet" href="{{ url('public/css/all.min.css') }}">
</head>
<body>
    <div class="main-wrapper">
        {% include 'layouts/sidebar.twig' %}

        <main>
            <header>
                <div class="search-bar">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Rechercher...">
                </div>
                <div class="profile-container">
                    <img src="{{ currentUser.imageProfile ? url('public/storage/profiles/' ~ currentUser.imageProfile) : url('public/images/default-profile.png') }}" class="avatar">
                    <div class="user-info">
                        <span class="nom">{{ currentUser.prenom }} {{ currentUser.nom }}</span>
                    </div>
                </div>
            </header>

            <div class="dashboard-body">
                <div class="verify-container">
                    <div class="table-header">
                        <h2>Vérification d'Identité</h2>
                        <p class="subtitle">Gestion des documents officiels des adhérents.</p>
                    </div>

                    <table>
                        <thead>
                            <tr>
                                <th>Utilisateur</th>
                                <th>Date</th>
                                <th>Documents</th>
                                <th style="text-align:right">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for iden in identifiers %}
                            <tr>
                                <td>
                                    <div class="user-cell">
                                        <img src="{{ iden.imageProfile ? url('public/storage/profiles/' ~ iden.imageProfile) : url('public/images/profil.png') }}">
                                        <div class="info">
                                            <span class="name">{{ iden.prenom }} {{ iden.nom }}</span>
                                            <span class="email">{{ iden.email }}</span>
                                        </div>
                                    </div>
                                </td>
                                <td><i class="fa-regular fa-calendar" style="margin-right: 5px; opacity: 0.5;"></i>{{ iden.dateModifier|date("d M Y") }}</td>
                                <td>
                                    {% set docs = [] %}
                                    {% if iden.cniRecto %}{% set docs = docs|merge([url('public/storage/identifiers/' ~ iden.cniRecto)]) %}{% endif %}
                                    {% if iden.cniVerso %}{% set docs = docs|merge([url('public/storage/identifiers/' ~ iden.cniVerso)]) %}{% endif %}
                                    {% if iden.passport %}{% set docs = docs|merge([url('public/storage/identifiers/' ~ iden.passport)]) %}{% endif %}
                                    <button class="view-btn" onclick="openVerifyModal('{{ iden.prenom }} {{ iden.nom }}', {{ docs|json_encode }}, '{{ iden.id }}')">
                                        <i class="fa-solid fa-eye"></i> Voir
                                    </button>
                                </td>
                                <td style="text-align:right">
                                    <button class="view-btn" onclick="handleAction('approve', '{{ iden.id }}')"><i class="fa-solid fa-check"></i></button>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <div id="verifyModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="m-userName">Vérification</h3>
                <span class="close" onclick="closeModal()">&times;</span>
            </div>
            <div class="modal-body">
                <div id="imageGallery" class="document-grid"></div>
                <div class="rejection-area">
				    <label>
                        <i class="fa-solid fa-envelope-open-text"></i>
                       Motif du refus :
                    </label>
                    <textarea id="rejectionMessage" placeholder="Motif du refus..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-danger" onclick="handleAction('reject')">Refuser</button>
                <button class="btn-success" onclick="handleAction('approve')">Approuver</button>
            </div>
        </div>
    </div>

    <div id="imagePreviewModal" class="image-viewer-modal">
        <span class="close-viewer" onclick="closeImageViewer()"><i class="fa-solid fa-xmark"></i></span>
        <div class="viewer-wrapper" id="viewerWrapper">
            <img id="fullImage">
        </div>
        <div class="viewer-controls">
            <button onclick="zoomImage(0.2)"><i class="fa-solid fa-magnifying-glass-plus"></i></button>
            <button onclick="zoomImage(-0.2)"><i class="fa-solid fa-magnifying-glass-minus"></i></button>
            <button onclick="resetZoom()"><i class="fa-solid fa-compress"></i></button>
        </div>
    </div>

    <script>
        let currentUserId = null;
        let scale = 1;

        function openVerifyModal(name, images, id) {
            currentUserId = id;
            document.getElementById('m-userName').innerText = name;
            const gallery = document.getElementById('imageGallery');
            gallery.innerHTML = '';
            images.forEach((src, i) => {
                const div = document.createElement('div');
                div.className = 'doc-item';
                div.innerHTML = `<img src="${src}" onclick="previewImage('${src}')"><span>Page ${i+1}</span>`;
                gallery.appendChild(div);
            });
            document.getElementById('verifyModal').style.display = "block";
        }

        function closeModal() { document.getElementById('verifyModal').style.display = "none"; }

        function previewImage(src) {
            const img = document.getElementById('fullImage');
            img.src = src;
            document.getElementById('imagePreviewModal').style.display = "flex";
            resetZoom();
        }

        function closeImageViewer() { document.getElementById('imagePreviewModal').style.display = "none"; }

        function zoomImage(delta) {
            scale += delta;
            if (scale < 0.5) scale = 0.5;
            if (scale > 4) scale = 4;
            const img = document.getElementById('fullImage');
            img.style.width = (scale * 90) + "%";
            img.style.maxWidth = "none"; 
        }

        function resetZoom() {
            currentZoom = 1;
            document.getElementById('fullImage').style.transform = "scale(1)";
         }

        async function handleAction(type, quickId = null) {
            const id = quickId || currentUserId;
            const msg = document.getElementById('rejectionMessage').value;
            if (type === 'reject' && !msg) return alert("Saisir un motif.");

            const fd = new FormData();
            fd.append('userId', id);
            fd.append('action', type);
            fd.append('reason', msg);

            try {
                const res = await fetch('/Tamghrabit/admin/identities/verify', { method: 'POST', body: fd });
                const data = await res.json();
                if (data.type === 'success') location.reload();
            } catch (e) { console.error(e); }
        }

        window.onclick = (e) => {
            if (e.target.className === 'modal') closeModal();
            if (e.target.id === 'imagePreviewModal') closeImageViewer();
        };
    </script>
</body>
</html>
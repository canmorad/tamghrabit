<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Tamghrabit - Dashboard Pro</title>
		<link rel="stylesheet" href="{{ url('public/css/dashboard.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/profile_pro.css') }}">
		<link rel="stylesheet" href="{{ url('public/css/all.min.css') }}">
	</head>
	<body>
		<div class="main-wrapper">
			{% include 'layouts/sidebar.twig' %}
			<main>
				<header>
					<div class="search-bar">
						<i class="fa-solid fa-magnifying-glass"></i>
						<input type="text" placeholder="Rechercher dans l'administration...">
					</div>
					
					<div class="action-buttons">
						<div class="profile-container">
							<img src="{{ currentUser.imageProfile ? url('public/storage/profiles/') ~ currentUser.imageProfile : url('public/images/default-profile.png')}}" alt="Admin" class="avatar">
							<div class="user-info">
								<span class="nom">{{ currentUser.nom ~ ' ' ~ currentUser.prenom }}</span>
								<span class="email">{{ currentUser.email }}</span>
							</div>
						</div>
					</div>
				</header>

				<section class="dashboard-body">
					<div id="profile-main-container">
						<nav class="profile-tabs">
							<button class="tab-btn active" onclick="switchTab(event, 'account')">
								<i class="fa-solid fa-user-shield"></i>
								Compte Pro
							</button>
						</nav>

						<div class="tab-separator"></div>

						<section id="account" class="tab-content active">
							<form action="{{ url('admin/profile/update') }}" method="POST" enctype="multipart/form-data">
								<div class="avatar-section">
									<div class="avatar-wrapper">
										<img src="{{ currentUser.imageProfile ? url('public/storage/profiles/') ~ currentUser.imageProfile : url('public/images/default-profile.png') }}" class="avatar-img" id="imagePreview">
										<label for="avatarInput" class="upload-badge">
											<i class="fa-solid fa-camera"></i>
										</label>
										<input type="file" id="avatarInput" name="imageProfile" hidden>
									</div>
								</div>

								<div class="grid-row">
									<div class="form-group">
										<label>Nom</label>
										<input type="text" name="nom" value="{{ currentUser.nom }}"  readonly >
									</div>
									<div class="form-group">
										<label>Prénom</label>
										<input type="text" name="prenom" value="{{ currentUser.prenom }}"  readonly>
									</div>
								</div>

								<div class="grid-row">
									<div class="form-group">
										<label>Email Professionnel</label>
										<input type="email" value="{{ currentUser.email }}" readonly >
									</div>
									
								</div>
							</form>
						</section>
					</div>
				</section>
			</main>
		</div>
		<script src="{{ url('public/js/profile_pro.js') }}"></script>
	</body>
</html>
